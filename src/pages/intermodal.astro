---
import MainLayout from '../layouts/MainLayout.astro';
import HeroBanner from '../components/HeroBanner.astro';
---

<MainLayout title="Intermodal" description="Intermodal shipping services - competitive rates for cross-border and intermodal freight transportation.">
  
  <HeroBanner title="Intermodal" backgroundImage="/images/hero-highway.png" />

  <section class="section">
    <div class="container">
      <div class="content-section">
        <div class="content-section__text">
          <h2>Intermodal Shipping Services</h2>
          <p>Lane Logistics Group provides competitive rates for the transportation of intermodal freight. We provide reliable and timely solutions for cross-border shipments. We are equipped to meet the demands of a global marketplace.</p>
          <p>Our intermodal services combine the best of rail and truck transportation to provide cost-effective and environmentally friendly shipping solutions. By leveraging our extensive network of carriers and rail partners, we can offer competitive rates without compromising on service quality.</p>
          <p>Whether you need to ship domestically or across borders, our intermodal services are designed to provide flexible and reliable transportation solutions that meet your business needs.</p>
          <a href="/contact-us" class="btn btn--primary" style="margin-top:15px;">Request A Quote</a>
        </div>
        <div class="content-section__image">
          <img src="/images/intermodal-truck.png" alt="Intermodal Transportation" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

</MainLayout>
