---
import MainLayout from '../layouts/MainLayout.astro';
import ServiceCard from '../components/ServiceCard.astro';
---

<MainLayout title="Home" description="Lane Logistics Group INC - Nationwide domestic truckload shipping from Business to Business in 48 States.">

  <!-- Home Hero Section -->
  <section class="home-hero">
    <div class="home-hero__slideshow">
      <div class="home-hero__slide active" style="background-image: url('/images/hero-highway.png')"></div>
      <div class="home-hero__slide" style="background-image: url('/images/hero-trucks-road.png')"></div>
      <div class="home-hero__slide" style="background-image: url('/images/hero-truck-sunset.png')"></div>
    </div>
    <div class="home-hero__overlay"></div>
    <div class="container">
      <div class="home-hero__text">
        <p class="home-hero__label">We Deliver Nationwide Logistics</p>
        <h1 class="home-hero__title">Lane Logistics<br>Group INC</h1>
        <p class="home-hero__subtitle">Ground, there is no stopping for us.</p>
        <div class="home-hero__buttons">
          <a href="/about-us" class="btn btn--primary">Learn More</a>
          <a href="tel:8883313640" class="btn btn--outline">Call Us: 888-331-3640</a>
        </div>
      </div>

      <!-- Quote Form -->
      <div class="quote-form quote-form--glass">
        <h3 class="quote-form__title">REQUEST A <span>Free Quote</span></h3>
        <form id="quoteForm">
          <div class="form-group">
            <input type="text" id="quote-name" placeholder="Full Name" required />
          </div>
          <div class="form-group">
            <input type="email" id="quote-email" placeholder="Email" required />
          </div>
          <div class="form-group">
            <input type="tel" id="quote-phone" placeholder="Phone" />
          </div>
          <div class="form-group">
            <textarea id="quote-message" placeholder="Message"></textarea>
          </div>
          <div class="recaptcha-box">
            <label class="recaptcha-label">
              <input type="checkbox" id="recaptcha-check" required />
              <span class="recaptcha-checkmark"></span>
              <span>I'm not a robot</span>
            </label>
            <div class="recaptcha-badge">
              <small>reCAPTCHA</small>
              <small>Privacy - Terms</small>
            </div>
          </div>
          <button type="submit" class="form-submit">Submit Message</button>
        </form>
      </div>
    </div>
  </section>

  <script>
    // Hero background slideshow
    const slides = document.querySelectorAll('.home-hero__slide');
    let current = 0;
    setInterval(() => {
      slides[current].classList.remove('active');
      current = (current + 1) % slides.length;
      slides[current].classList.add('active');
    }, 3000);
  </script>

  <!-- Nationwide Shipping Service Section -->
  <section class="section">
    <div class="container">
      <div class="content-section">
        <div class="content-section__text">
          <p class="section-label">Nationwide Shipping Service</p>
          <h2>Lane Logistics<br>Group INC</h2>
          <div class="highlight">
            Lane Logistics Group Inc is a transportation services that provides domestic truckload shipping from Business to Business in 48 States.
          </div>
          <p>We make the shipper's load a priority, and we are working diligently every day to ensure the quality we have provided is beyond ordinary.</p>
          <p>Our mission is to modernize, fix, and improve your supply chain.</p>
          <div class="hero-actions-row">
            <a href="/about-us" class="btn btn--primary">Learn More</a>
            <div class="support-box support-box--inline">
              <svg width="22" height="22" viewBox="0 0 24 24" fill="currentColor" style="color:#fff"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
              <div>
                <small style="opacity:0.85;font-size:0.75rem;">Our 24/7 Emergency Phone Services</small><br>
                <strong style="font-size:1.05rem;">Call: 888-331-3640</strong>
              </div>
            </div>
          </div>
        </div>
        <div class="content-section__image content-section__image--overflow">
          <img src="/images/truck-cutout.png" alt="Lane Logistics Truck" loading="lazy" />
        </div>
      </div>
    </div>
  </section>

  <!-- Our Services Section -->
  <section class="section section--gray">
    <div class="container">
      <div class="services-intro-grid">
        <div>
          <p class="section-label">Our Services</p>
          <h2 class="section-title">What We Offer</h2>
          <p>Our company is dedicated to your success beside that it provides outstanding customer service. Lane Logistics Group specializes in full truckload shipments and can also assist with your LTL needs in 48 States. Our group is comprised of 3rd party logistic professionals who care about the product being shipped. We are truly a registered property broker (MC#1431130) that is bonded and insured.</p>
        </div>
        <div class="support-box">
          <p class="support-box__label">24/7 Customer Support</p>
          <h3>Go Beyond Logistics, Make The World Go Round</h3>
          <p>Our normal hours of operation are 8:30AM to 5:30PM EST, M-F. For dispatch issues, we can always be reached by phone, 24x7x365 at 888-331-3640 or 754-348-0247.</p>
          <a href="/services" class="btn btn--outline" style="margin-top:15px;">View All Services</a>
        </div>
      </div>

      <div class="services-grid">
        <ServiceCard
          title="Full Truck Load"
          text="We can ship an entire semi-trailer container for you for any states in the US except Alaska and Hawaii, and it is the same for Less-Than Truckload."
          icon="/images/icon-ftl.svg"
          href="/full-truck-load"
        />
        <ServiceCard
          title="LTL"
          text="The load-to-truck ratio is a critical aspect of the trucking industry and one of the many reasons why we offer an exclusive LTL service. We have maintained an efficient business model that allows us to provide you with a wide selection of your shipping needs."
          icon="/images/icon-ltl.svg"
          href="/ltl"
        />
        <ServiceCard
          title="Intermodal"
          text="Lane Logistics Group provides competitive rates for the transportation of intermodal freight. We provide reliable and timely solutions for cross-border shipments. We are equipped to meet the demands of a global marketplace."
          icon="/images/icon-intermodal.svg"
          href="/intermodal"
        />
      </div>
    </div>
  </section>

  <!-- Why Choose Us Section -->
  <section class="section">
    <div class="container" style="text-align:center;">
      <p class="section-label">Our Best Business</p>
      <h2 class="section-title">Why Choose Us</h2>
      <p style="max-width:900px;margin:0 auto 15px;">Every day we certify all our carriers to make sure they have the proper authority and insurance to do the job. In addition to that we monitor your loads from pick up until delivery. Our company works with carriers that have clean record in the sector. When we take the loads from you, we guarantee you all of them will get on time at destination.</p>
      <p style="max-width:900px;margin:0 auto 15px;">Lane logistics group gives three convenient options for you to book your loads. You can email us, fax us or call us to book them. We also give two convenient billing options. We can email or fax your freight bills.</p>
      <p style="max-width:900px;margin:0 auto 15px;">Lane Logistics Group inc provides quotes free of charge or obligation. There is no doubt, we will give you a reasonable quote for the load we want to haul for you.</p>
      <p style="max-width:900px;margin:0 auto 30px;">In order to provide shippers the most convenient service possible, we give 3 choices for requesting a quote.</p>

      <!-- Truck center with features around it -->
      <div class="why-choose-layout">
        <div class="why-choose-left">
          <div class="feature-item feature-item--right">
            <div>
              <h4 class="feature-item__title">Worldwide Locations</h4>
              <p class="feature-item__text">Our safe and secure transportation network is unmatched throughout the globe, resulting in an exceptional level of service.</p>
            </div>
            <div class="feature-item__icon">✓</div>
          </div>
          <div class="feature-item feature-item--right">
            <div>
              <h4 class="feature-item__title">Quality and Commitment</h4>
              <p class="feature-item__text">Our reputation has been built by providing excellent service that protects both the customer and their cargo.</p>
            </div>
            <div class="feature-item__icon">✓</div>
          </div>
        </div>

        <div class="why-choose-center">
          <img src="/images/truck-center.png" alt="Lane Logistics Truck" />
        </div>

        <div class="why-choose-right">
          <div class="feature-item">
            <div class="feature-item__icon">✓</div>
            <div>
              <h4 class="feature-item__title">24/7 Customer Support</h4>
              <p class="feature-item__text">Our customer service team is available to assist you with any questions or concerns you might have, 24/7.</p>
            </div>
          </div>
          <div class="feature-item">
            <div class="feature-item__icon">✓</div>
            <div>
              <h4 class="feature-item__title">100% Safe Delivery</h4>
              <p class="feature-item__text">All of our drivers are CRI checked to assure that our drivers are safe and trustworthy.</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Get Started Today Section -->
  <section class="get-started-section">
    <div class="get-started-bg" style="background-image: url('/images/getstarted-bg.png')"></div>
    <div class="container get-started-content">
      <p class="section-label" style="color:var(--color-text-medium);">Get Started Today</p>
      <h2 style="color:var(--color-navy);margin-bottom:25px;">Are You Ready To Work Together</h2>
      <div class="get-started-buttons">
        <a href="/contact-us" class="btn btn--primary">Contact Us</a>
        <a href="tel:8883313640" class="btn btn--outline-red">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="vertical-align:middle;margin-right:6px;"><path d="M6.62 10.79c1.44 2.83 3.76 5.14 6.59 6.59l2.2-2.2c.27-.27.67-.36 1.02-.24 1.12.37 2.33.57 3.57.57.55 0 1 .45 1 1V20c0 .55-.45 1-1 1-9.39 0-17-7.61-17-17 0-.55.45-1 1-1h3.5c.55 0 1 .45 1 1 0 1.25.2 2.45.57 3.57.11.35.03.74-.25 1.02l-2.2 2.2z"/></svg>
          888-331-3640
        </a>
      </div>
    </div>
  </section>

  <!-- Quality & Commitment Section -->
  <section class="section">
    <div class="container">
      <div class="content-section">
        <div class="quality-images">
          <img src="/images/quality-sunset.png" alt="Highway at sunset" class="quality-img-top" />
          <img src="/images/quality-truck.png" alt="Red truck on highway" class="quality-img-bottom" />
        </div>
        <div class="content-section__text">
          <h2>Quality and Commitment</h2>
          <p>We are committed to have a cordial relationship with our carriers. Our goal is to develop a relationship based on trust, integrity, and confidence. As you know, trust comes when we treat every carrier with fairness. Certainly, we have committed to pay you the right amount for the load.</p>
          <p>If you want to do business with a brokerage company that knows the carriers are important, please contact us.</p>
          <a href="/contact-us" class="btn btn--primary" style="margin-top:15px;">Contact Us</a>
        </div>
      </div>
    </div>
  </section>

</MainLayout>
